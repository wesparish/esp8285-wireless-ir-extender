#!/usr/bin/env bash
# Open a serial monitor for a connected device.
#
# Usage:
#   ./bin/monitor [port]
#
# Examples:
#   ./bin/monitor
#   ./bin/monitor /dev/ttyUSB0

set -euo pipefail

PORT=${1:-}
FLAGS=(--baud 115200)

if [[ -n "$PORT" ]]; then
    FLAGS+=(--port "$PORT")
fi

pio device monitor "${FLAGS[@]}"
